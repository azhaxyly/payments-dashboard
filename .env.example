# Хранение. Локально — SQLite-файл; в проде — Postgres (Neon): postgres://...
DATABASE_URL=file:./dev.db

# Ключ Anthropic. Если НЕ задан — ingest использует MockExtractor (golden-fixture),
# демо и CI работают без ключа.
ANTHROPIC_API_KEY=

# Модель AI-парсинга: claude-opus-4-8 (качество) | claude-sonnet-4-6 (скорость/цена)
AI_MODEL=claude-opus-4-8

# «Сегодня» для логики «требует внимания» (по умолчанию конец периода выписки)
NOW=2026-08-09
# Порог в днях для статуса «требует внимания»
ATTENTION_DAYS=21
